# FastAPI 应用配置
APP_NAME=AiInterviewAgent
DEBUG=True
VERSION=1.0.0

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_interview
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10

# JWT 配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Qwen AI 配置
QWEN_API_KEY=your-qwen-api-key

# 阿里云配置（OSS、ASR 等）
ALIYUN_ACCESS_KEY=your-aliyun-access-key
ALIYUN_SECRET_KEY=your-aliyun-secret-key
ALIYUN_OSS_BUCKET=your-oss-bucket
ALIYUN_ASR_APPKEY=your-asr-appkey
ALIYUN_TTS_APPKEY=

# TTS 配置
# TTS_PROVIDER: auto | xfyun | aliyun | qwen | mock
# auto 会根据配置自动选择可用的 TTS 服务
TTS_PROVIDER=auto

# 讯飞星火 TTS 配置（推荐）
# 获取地址: https://www.xfyun.cn/
XFYUN_APP_ID=your-xfyun-app-id
XFYUN_APP_KEY=your-xfyun-api-key
XFYUN_APP_SECRET=your-xfyun-api-secret
XFYUN_VOICE=xiaoyan  # xiaoyan, xiaofeng, xiaomei, xiaoyu, xiaoxin
XFYUN_SPEED=50       # 0-100
XFYUN_VOLUME=50      # 0-100
XFYUN_PITCH=50       # 0-100

# Qwen TTS 配置（备选）
QWEN_API_KEY=your-qwen-api-key

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 日志配置
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_JSON_FORMAT=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_CONSOLE=true

# SMTP 邮件配置
# 用于发送验证码邮件
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=your-email@qq.com
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# 推荐系统数据库配置
# 注意：推荐系统已合并到主数据库 ai_interview
# 保留此配置用于向后兼容，应与 DATABASE_URL 指向同一数据库
REC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:15432/ai_interview

# ============================================
# 本地开发配置说明
# ============================================
#
# 方式1: 使用 Docker 基础设施 (推荐)
#   1. 在项目根目录运行: docker-compose -f docker-compose.infra.yml up -d
#   2. 使用以下配置:
#      DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:15432/ai_interview
#      REDIS_URL=redis://localhost:16379/0
#      MILVUS_HOST=localhost
#      MILVUS_PORT=29530
#
# 方式2: 使用本地安装的服务
#   - 修改端口为本地服务端口 (5432, 6379 等)
#
# 详见: INFRA_SETUP.md
